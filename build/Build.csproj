<!-- Purpose: ModularPipelines build project -->
<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <RootNamespace>Build</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="ModularPipelines" Version="3.*" />
        <PackageReference Include="ModularPipelines.DotNet" Version="3.*" />
        <PackageReference Include="ModularPipelines.Git" Version="3.*" />
        <PackageReference Include="ModularPipelines.GitHub" Version="3.*" />
        <PackageReference Include="Microsoft.VisualStudio.SolutionPersistence" Version="1.*" />
        <PackageReference Include="Sourcy.DotNet" Version="1.*" />
        <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" Version="10.*" />
        <PackageReference Include="Shouldly" Version="4.*" />
    </ItemGroup>

    <ItemGroup>
        <None Update="appsettings.json" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

</Project>
